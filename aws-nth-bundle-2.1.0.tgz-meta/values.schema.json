{
    "$schema": "http://json-schema.org/schema#",
    "type": "object",
    "additionalProperties": true,
    "properties": {
        "ociRepositoryUrl": {
            "type": "string"
        },
        "clusterID": {
            "type": "string"
        },
        "managementCluster": {
            "type": "string"
        },
        "region": {
            "type": "string"
        },
        "awsNodeTerminationHandler": {
            "type": "object",
            "properties": {
                "dependsOn": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": {
                                "type": "string"
                            },
                            "namespace": {
                                "type": "string"
                            }
                        },
                        "required": ["name"]
                    }
                }
            }
        }
    }
}
